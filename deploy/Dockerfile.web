# ===== Build frontend =====
FROM node:20-alpine AS fe_build
WORKDIR /app
COPY TutorAppFrontend/package*.json ./
RUN npm ci
COPY TutorAppFrontend/ ./
RUN npm run build

# ===== Nginx serving static + proxy =====
FROM nginx:alpine
COPY nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=fe_build /app/dist /usr/share/nginx/html